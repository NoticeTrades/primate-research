# ───────────────────────────────────────
# Neon Postgres Database
# ───────────────────────────────────────
# 1. Go to https://neon.tech and sign up (free)
# 2. Create a project → copy the connection string
# 3. Paste it here AND add it to Vercel environment variables
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ───────────────────────────────────────
# Resend — Email Notifications
# ───────────────────────────────────────
# 1. Go to https://resend.com and sign up (free)
# 2. Create an API key → paste it here
RESEND_API_KEY=re_xxxxxxxxx

# The "from" address for notification emails.
# Free tier: use "Primate Research <notifications@resend.dev>"
# Custom domain: verify in Resend, then use your own address.
RESEND_FROM_EMAIL="Primate Research <notifications@resend.dev>"

# Optional: get a copy of every report notification at this address (e.g. your personal email).
# Useful if the email you signed up with doesn't receive the blast or you want a backup.
# NOTIFY_CC_EMAIL=your-email@gmail.com

# ───────────────────────────────────────
# Admin / Notify Secret
# ───────────────────────────────────────
# Pick any secret passphrase. Used to access /admin and send notifications.
NOTIFY_SECRET=your-secret-key-here

# ───────────────────────────────────────
# Site URL (used in email links)
# ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://primate-research.vercel.app

# ───────────────────────────────────────
# Twilio — SMS for live trade alerts (optional)
# ───────────────────────────────────────
# 1. Sign up at https://twilio.com and get a phone number
# 2. Account SID and Auth Token from Twilio console
# 3. Use the Twilio number in E.164 format (e.g. +15551234567)
# If not set, SMS alerts are skipped; email and bell still work.
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+15551234567

# ───────────────────────────────────────
# Twelve Data — Real-time futures (NQ, ES, YM, RTY, CL) for ticker & Live Trades
# ───────────────────────────────────────
# Without this, the site uses Yahoo Finance which is 10–15 min delayed for CME futures.
# Get a key at https://twelvedata.com — free tier has real-time. Add to Vercel env vars.
# TWELVE_DATA_API_KEY=your-twelve-data-key

# ───────────────────────────────────────
# Alpha Vantage — MOST command (Active / Gainers / Losers / Value)
# ───────────────────────────────────────
# 1. Go to https://www.alphavantage.co/support/#api-key
# 2. Get a free API key and add it here and in Vercel env vars
# If not set, the MOST terminal command will show an error.
# ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# ───────────────────────────────────────
# YouTube (optional — view counts + live indicator on homepage)
# ───────────────────────────────────────
# YOUTUBE_API_KEY=your-youtube-data-api-v3-key
# Live indicator uses channel handle (no @) or channel ID:
# YOUTUBE_CHANNEL_HANDLE=noticetrades
# YOUTUBE_CHANNEL_ID=UCxxxxxxxx  # optional; overrides handle if set
